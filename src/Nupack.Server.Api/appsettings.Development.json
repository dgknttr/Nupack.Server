{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Nupack.Server.Api.Services.BaseUrlResolver": "Debug"
    }
  },
  "NuGetServer": {
    "BaseUrl": "http://localhost:5003"
  },
